    <powerups>
        <powerup id="tripple_shot">
            <name>Tripple Shot</name>
            <symbol>T</symbol>
            <color>#FFD600</color> <!-- Bright yellow -->
            <size>graviton</size>  <!-- Use graviton ship size for reference -->
            <duration>8</duration> <!-- 20 seconds -->
            <initialSpeedMin>0.3</initialSpeedMin>
            <initialSpeedMax>0.7</initialSpeedMax>
            <radius>14</radius>
            <description>Fires three projectiles at once</description>
        </powerup>
        <maxVelocity>2</maxVelocity>
        <attractDistance>100</attractDistance> <!-- Distance at which ship attracts powerups -->
        <attractForce>1</attractForce> <!-- Strength of the attract force -->
        <spawnChanceLarge>0.03</spawnChanceLarge> <!-- 3% chance -->
        <spawnChanceMedium>0.05</spawnChanceMedium> <!-- 5% chance -->
    </powerups>

