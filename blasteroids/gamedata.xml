<?xml version="1.0" encoding="UTF-8"?>
<blasteroids>
    
    <ship>
        <thrust>0.3</thrust>
        <rotationSpeed>0.1</rotationSpeed>
        <maxSpeed>8</maxSpeed>
        <friction>0.98</friction>
        <shieldDuration>240</shieldDuration>
        <projectile>
            <speed>10</speed>
            <lifetime>60</lifetime>
        </projectile>
        <fireCooldown>12</fireCooldown>
        <gridLighting>
            <intensity>1.0</intensity>
            <radius>40</radius>
        </gridLighting>
    </ship>
    
    <physics>
        <debrisFriction>0.99</debrisFriction>
    </physics>

	<gameplay>
    		<gameOverScreenDuration>2</gameOverScreenDuration>
    		<attractModeDuration>10</attractModeDuration>
    		<attractMusicCooldown>20</attractMusicCooldown>
    		<attractMusicPlayTime>8</attractMusicPlayTime>
    		<textCollisionFragmentChance>0.15</textCollisionFragmentChance>
    		<textCollisionColorChangeCount>5</textCollisionColorChangeCount>
    		<textCollisionPacmanSpawnChance>0.10</textCollisionPacmanSpawnChance>
    		<pacmanLimit>1</pacmanLimit>
    		<pacmanVolume>0.01</pacmanVolume>
    		<novabombVolume>0.1</novabombVolume>
    		<noShipSpawnChance>0.15</noShipSpawnChance>
    		<waveTransitionDelay>60</waveTransitionDelay>
    		<endOfWaveDelay>2</endOfWaveDelay>
    		<transitionOutDuration>5</transitionOutDuration>
    		<transitionStars>
    			<count>100</count>
    			<minSpeed>2</minSpeed>
    			<maxSpeed>40</maxSpeed>
    		</transitionStars>
    		<attractModeEnemySpawning>
    			<spawnInterval>5</spawnInterval>
    			<enemyTypes>
    				<saucer>0.3</saucer>
    				<graviton>0.2</graviton>
    				<cygnus>0.1</cygnus>
    				<novabomb>0.1</novabomb>
    				<nothing>0.3</nothing>
    			</enemyTypes>
    		</attractModeEnemySpawning>
    		<textColors>
    			<color>yellow</color>
    			<color>lightblue</color>
    			<color>white</color>
    			<color>lightgreen</color>
    			<color>lightorange</color>
    		</textColors>
	</gameplay>

    <enemies>
        <saucer>
            <score>200</score>
        </saucer>
        <asteroids>
            <scoreLarge>10</scoreLarge>
            <scoreMedium>20</scoreMedium>
            <scoreSmall>50</scoreSmall>
        </asteroids>
        <cygnus>
            <rotationSpeed>0.062</rotationSpeed>
            <scoreNormal>500</scoreNormal>
            <scoreEscaping>2000</scoreEscaping>
        </cygnus>
        <novabomb>
            <radius>130</radius>
            <pushForce>12</pushForce>
            <score>1000</score>
        </novabomb>
        <graviton>
            <tractorPullSpeed>0.8</tractorPullSpeed>
            <tractorTangentialForce>0.150</tractorTangentialForce>
            <tractorMaxOrbitalSpeed>3.0</tractorMaxOrbitalSpeed>
            <kickForce>4</kickForce>
            <score>500</score>
            <baseOrbitRadius>240</baseOrbitRadius>
            <maxCapturedAsteroidSpeed>4.0</maxCapturedAsteroidSpeed>
        </graviton>
    </enemies>

    <world>
        <blackHole>
            <pullRadiusRatio>0.30</pullRadiusRatio>
            <minPull>0.00325</minPull>
            <maxPull>0.0725</maxPull>
            <lethalRadius>5</lethalRadius>
            <growth>0.20</growth>
            <darkeningRadius>6.0</darkeningRadius>
            <shockwaveIntensity>40</shockwaveIntensity>
            <shockwaveSpeed>6</shockwaveSpeed>
            <shadowSpinMultiplier>2.0</shadowSpinMultiplier>
            <shadowLayers>3</shadowLayers>
            <shadowOpacity>0.9</shadowOpacity>
        </blackHole>
        <grid>
            <opacity>0.10</opacity>
        </grid>
    </world>

